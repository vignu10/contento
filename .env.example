# Database
DATABASE_URL="file:./dev.db"

# Redis (supports redis:// and rediss:// URLs with optional password)
REDIS_URL="redis://localhost:6379"

# OpenAI (REQUIRED - app will not start without this)
OPENAI_API_KEY="sk-..."

# AWS S3 (optional - required for file uploads in production)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET="content-repurposing"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# JWT Secret (REQUIRED - must be a secure random string in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=""

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
